{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Writer",
  "version": "0.3.8",
  "identifier": "com.writer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:43173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Writer",
        "width": 1180,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
