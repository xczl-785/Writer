{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Writer",
  "version": "0.3.11",
  "identifier": "com.writer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:43173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Writer",
        "width": 1180,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md"
        ],
        "name": "Writer",
        "description": "Writer Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": [
          "markdown"
        ],
        "name": "Writer",
        "description": "Writer Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDMTk3NTE4RTJCQTI3MjAKUldRZ0o3cmlHSFVaWENtMFlKNGVnUG1ackpWb1B1MEJEVGw2L2hIQVVTaVhBd3VMbUlWb2dTb2MK",
      "endpoints": [
        "https://github.com/xczl-785/Writer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
